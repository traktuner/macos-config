#!/usr/bin/env bash
set -eo pipefail

# Prevent running as root
if [[ $(id -u) -eq 0 ]]; then
  echo "Please run bootstrap as your user, not root. Aborting."
  exit 1
fi

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR" || { echo "Could not cd to $ROOT_DIR"; exit 1; }

# Load shared functions
source "$ROOT_DIR/core/functions.sh"

# Export helpers into subshells
export ROOT_DIR
export -f ask_for_confirmation ask_for_sudo answer_is_yes
export -f print_info print_success print_error log_message
export -f symlink_from_to modify_file modify_line
export -f insert_to_file_after_line_number uncomment_line prepend_string_to_file
export -f line_exists add_config get_arch command_exists
export -f retry safe_defaults_write safe_plistbuddy safe_killall
export -f ensure_directory download_file bootstrap_launch_daemon tm_snapshot
export -f request_full_disk_access check_macos_version

# System validation
print_info "Validating system requirements..."
if ! check_macos_version "14.0"; then
  print_error "This script requires macOS 14.0 (Sonoma) or higher"
  exit 1
fi

print_info "System information:"
get_system_info

# Check for required commands
for cmd in curl git; do
  if ! command_exists "$cmd"; then
    print_error "Required command '$cmd' not found"
    exit 1
  fi
done

# Check internet connectivity
if ! curl -fsS --max-time 5 https://github.com >/dev/null 2>&1; then
  print_error "No internet connection detected. Please connect to the internet and try again."
  exit 1
fi
print_success "Internet connectivity verified"

ask_for_sudo

print_info "Welcome to your macOS setup bootstrap!"

# Collect all utils scripts into an array
UTILS=()
for f in "$ROOT_DIR/utils"/*.sh; do
  [[ -f "$f" ]] || continue
  UTILS+=("$f")
done

if [[ ${#UTILS[@]} -eq 0 ]]; then
  print_error "No scripts found in $ROOT_DIR/utils/"
  exit 1
fi

# Display menu
echo
echo "Please choose an action:"
echo "  0) Run full setup (all scripts)"
i=1
for script in "${UTILS[@]}"; do
  echo "  $i) Run $(basename "$script")"
  ((i++))
done
echo "  *) You can also enter a range (e.g., 1-3) or a list (e.g., 1,3,7)"
echo "  q) Quit"
echo

# Function to check and request Full Disk Access if 03-macos.sh is selected
check_fda_for_scripts() {
  local scripts=("$@")
  for script in "${scripts[@]}"; do
    if [[ "$(basename "$script")" == "03-macos.sh" ]]; then
      print_info "03-macos.sh selected - Full Disk Access required"
      if ! request_full_disk_access; then
        print_error "Full Disk Access is required to continue."
        return 1
      fi
      return 0
    fi
  done
}

# Function to execute scripts with error tracking
run_scripts() {
  local scripts=("$@")
  local failed=0
  for script in "${scripts[@]}"; do
    print_info "Running $(basename "$script")..."
    if bash "$script"; then
      print_success "Completed: $(basename "$script")"
    else
      print_error "Failed: $(basename "$script")"
      ((failed++))
    fi
  done
  if ((failed > 0)); then
    print_error "$failed script(s) had errors. Check the log for details."
  fi
}

# Handle choice
while true; do
  read -rp "Enter choice [0-$((i - 1)), range, list, q]: " choice
  case "$choice" in
    [Qq])
      echo "Goodbye!"
      exit 0
      ;;
    0)
      check_fda_for_scripts "${UTILS[@]}" || exit 1
      print_info "Running all setup scripts..."
      run_scripts "${UTILS[@]}"
      break
      ;;
    *)
      # Parse range and list input (e.g., "1-3" or "1,3,7" or "1,3,5-7")
      scripts_to_run=()
      is_valid=true

      for item in ${choice//,/ }; do
        if [[ "$item" =~ ^([0-9]+)-([0-9]+)$ ]]; then
          start="${BASH_REMATCH[1]}"
          end="${BASH_REMATCH[2]}"
          if ((start > end)); then
            print_error "Invalid range '$item': start > end."
            is_valid=false
            break
          fi
          for num in $(seq "$start" "$end"); do
            scripts_to_run+=("$num")
          done
        elif [[ "$item" =~ ^[0-9]+$ ]]; then
          scripts_to_run+=("$item")
        else
          print_error "Invalid input: '$item'"
          is_valid=false
          break
        fi
      done

      $is_valid || continue

      if [[ ${#scripts_to_run[@]} -eq 0 ]]; then
        print_error "No valid scripts selected."
        continue
      fi

      # Deduplicate and validate selections
      final_script_paths=()
      seen=""
      is_valid=true

      for num in "${scripts_to_run[@]}"; do
        if ((num < 1 || num >= i)); then
          print_error "Choice '$num' is out of range (1-$((i - 1)))."
          is_valid=false
          break
        fi
        index=$((num - 1))
        sel_script="${UTILS[index]}"
        if [[ ":$seen:" != *":$sel_script:"* ]]; then
          final_script_paths+=("$sel_script")
          seen="$seen:$sel_script"
        fi
      done

      $is_valid || continue

      if [[ ${#final_script_paths[@]} -eq 0 ]]; then
        print_error "No valid scripts selected."
        continue
      fi

      check_fda_for_scripts "${final_script_paths[@]}" || exit 1
      print_info "Running selected setup scripts..."
      run_scripts "${final_script_paths[@]}"
      break
      ;;
  esac
done

print_success "Done! You can now close this terminal."
print_info "Log file available at: $LOG_FILE"
